<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#12162A"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Wave Music"
            android:textColor="#F8FAFC"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_artist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Escolha uma música"
            android:textColor="#AAB4D0"
            android:textSize="13sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <Button
            android:id="@+id/widget_previous"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:backgroundTint="#222A45"
            android:text="‹"
            android:textColor="#F8FAFC"
            android:textSize="20sp" />

        <Button
            android:id="@+id/widget_play_pause"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginStart="6dp"
            android:backgroundTint="#8B5CF6"
            android:text="Tocar"
            android:textColor="#F8FAFC" />

        <Button
            android:id="@+id/widget_next"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="6dp"
            android:backgroundTint="#22D3EE"
            android:text="›"
            android:textColor="#070814"
            android:textSize="20sp" />

        <Button
            android:id="@+id/widget_favorite"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="6dp"
            android:backgroundTint="#EC4899"
            android:text="♥"
            android:textColor="#F8FAFC"
            android:textSize="16sp" />
    </LinearLayout>
</LinearLayout>
